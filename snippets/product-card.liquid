{% comment %}
  Product Card Snippet
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{%- assign card_product = product -%}

<article class="product-card" itemscope itemtype="https://schema.org/Product">
  <a href="{{ card_product.url }}" class="product-card__link" aria-label="{{ card_product.title | escape }}">
    <div class="product-card__image-wrapper">
      {%- if card_product.featured_image -%}
        <img
          class="product-card__image"
          src="{{ card_product.featured_image | image_url: width: 600 }}"
          alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
          width="600"
          height="800"
          loading="lazy"
          itemprop="image"
        >
      {%- else -%}
        <div class="product-card__image product-card__image--placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" style="width:40%;height:40%;margin:auto;opacity:0.2;">
            <rect x="3" y="3" width="18" height="18" rx="1"/>
            <path d="M9 9l6 6M15 9l-6 6"/>
          </svg>
        </div>
      {%- endif -%}

      {%- if card_product.compare_at_price > card_product.price -%}
        <span class="product-card__badge product-card__badge--sale">Sale</span>
      {%- elsif card_product.tags contains 'new' or card_product.tags contains 'nieuw' -%}
        <span class="product-card__badge">Nieuw</span>
      {%- endif -%}

      <div class="product-card__quick-add" aria-hidden="true">Snel toevoegen</div>
    </div>

    <div class="product-card__info">
      {%- if card_product.type != blank -%}
        <div class="product-card__category">{{ card_product.type }}</div>
      {%- endif -%}
      <h3 class="product-card__name" itemprop="name">{{ card_product.title }}</h3>
      <div class="product-card__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        {%- if card_product.compare_at_price > card_product.price -%}
          <span class="product-card__price--compare">{{ card_product.compare_at_price | money }}</span>
          <span class="product-card__price--sale" itemprop="price" content="{{ card_product.price | divided_by: 100.0 }}">{{ card_product.price | money }}</span>
        {%- else -%}
          <span itemprop="price" content="{{ card_product.price | divided_by: 100.0 }}">{{ card_product.price | money }}</span>
        {%- endif -%}
        <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
      </div>
    </div>
  </a>
</article>
