{% comment %} Header Section {% endcomment %}

<header class="header{% if section.settings.transparent_on_home == false %} header--white{% endif %}" id="SiteHeader" role="banner">
  <div class="header__inner">

    <!-- Logo -->
    <div class="header__logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: height: 72 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            height="36"
            width="{{ section.settings.logo.width | times: 36 | divided_by: section.settings.logo.height }}"
          >
        {%- else -%}
          {% render 'logo', variant: 'dark' %}
        {%- endif -%}
      </a>
    </div>

    <!-- Desktop Navigation -->
    <nav class="header__nav" aria-label="Hoofdnavigatie">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links == blank -%}
          <a
            href="{{ link.url }}"
            class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        {%- else -%}
          <div class="header__nav-dropdown">
            <button class="header__nav-link header__nav-link--dropdown" aria-expanded="false" aria-haspopup="true">
              {{ link.title }}
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
            </button>
            <ul class="header__dropdown">
              {%- for child_link in link.links -%}
                <li>
                  <a href="{{ child_link.url }}" class="header__dropdown-link"
                    {% if child_link.current %}aria-current="page"{% endif %}
                  >{{ child_link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <!-- Right Actions -->
    <div class="header__actions">
      <!-- Search -->
      <button
        class="header__action-btn header__action-btn--hidden-mobile"
        onclick="openSearch()"
        aria-label="Zoeken"
      >{% render 'icon-search' %}</button>

      <!-- Cart -->
      <button
        class="header__action-btn"
        data-cart-open
        aria-label="Winkelwagen openen"
      >
        <span class="header__cart-wrapper">
          {% render 'icon-cart' %}
          <span class="header__cart-count" style="display:none;">0</span>
        </span>
      </button>

      <!-- Hamburger (mobile) -->
      <button
        id="Hamburger"
        class="hamburger"
        aria-label="Menu openen"
        aria-expanded="false"
        aria-controls="MobileMenu"
      >
        {% render 'icon-hamburger' %}
      </button>
    </div>

  </div>
</header>

<!-- Mobile Menu -->
<nav
  id="MobileMenu"
  class="mobile-menu"
  aria-label="Mobiele navigatie"
  aria-hidden="true"
>
  {%- for link in linklists[section.settings.menu].links -%}
    <a
      href="{{ link.url }}"
      class="mobile-menu__link"
      onclick="closeMobileMenu()"
      {% if link.current %}aria-current="page"{% endif %}
    >{{ link.title }}</a>
  {%- endfor -%}
  <a href="{{ routes.cart_url }}" class="mobile-menu__link" onclick="closeMobileMenu()">Winkelwagen</a>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo afbeelding"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 170,
      "unit": "px",
      "label": "Logo breedte"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigatiemenu"
    },
    {
      "type": "checkbox",
      "id": "transparent_on_home",
      "label": "Transparant op homepage",
      "default": true
    }
  ]
}
{% endschema %}
