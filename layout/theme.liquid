<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#ffffff">

  <title>
    {%- if page_title == blank -%}
      {{ shop.name }}
    {%- elsif request.page_type == 'index' -%}
      {{ page_title }} — {{ shop.name }}
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <!-- Google Fonts: Inter + Cormorant Garamond -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ request.page_type }}">

  <!-- Skip to content -->
  <a class="visually-hidden skip-link" href="#MainContent">Ga naar inhoud</a>

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- Cart Drawer Overlay -->
  <div id="CartOverlay" class="cart-overlay" aria-hidden="true"></div>

  <!-- Cart Drawer -->
  <div id="CartDrawer" class="cart-drawer" role="dialog" aria-modal="true" aria-label="Winkelwagen" aria-hidden="true">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Winkelwagen</h2>
      <button class="cart-drawer__close" id="CartDrawerClose" aria-label="Sluiten">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 4l12 12M16 4L4 16"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__body" id="CartDrawerBody">
      <div class="cart-drawer__loading" id="CartDrawerLoading" style="display:none;">
        <div class="spinner"></div>
      </div>
      <div id="CartDrawerItems"></div>
      <div id="CartDrawerEmpty" class="cart-drawer__empty" style="display:none;">
        <p class="cart-drawer__empty-text">Je winkelwagen is leeg</p>
        <button class="btn-outline cart-drawer__continue" onclick="closeCartDrawer()">Verder winkelen</button>
      </div>
    </div>

    <div class="cart-drawer__footer" id="CartDrawerFooter" style="display:none;">
      <div class="cart-drawer__subtotal">
        <span>Subtotaal</span>
        <span id="CartDrawerTotal"></span>
      </div>
      <p class="cart-drawer__shipping-note">Verzendkosten berekend bij afrekenen</p>
      <a href="/checkout" class="btn-primary cart-drawer__checkout">Afrekenen</a>
      <button class="btn-outline cart-drawer__continue-btn" onclick="closeCartDrawer()">Verder winkelen</button>
    </div>
  </div>

  <!-- Mobile Search Overlay -->
  <div id="SearchOverlay" class="search-overlay" aria-hidden="true">
    <div class="search-overlay__inner">
      <form action="/search" method="get" class="search-overlay__form">
        <input type="hidden" name="type" value="product">
        <input
          type="text"
          name="q"
          class="search-overlay__input"
          placeholder="Zoek producten..."
          autocomplete="off"
          autofocus
        >
        <button type="submit" class="search-overlay__submit" aria-label="Zoeken">
          {% render 'icon-search' %}
        </button>
      </form>
      <button class="search-overlay__close" onclick="closeSearch()" aria-label="Sluiten">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
    </div>
  </div>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
